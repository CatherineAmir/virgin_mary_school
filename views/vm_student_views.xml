        <!-- Action and Menu -->
        <record id="action_vm_student" model="ir.actions.act_window">
            <field name="name">Students</field>
            <field name="res_model">vm.student</field>
            <field name="view_mode">kanban,list,form</field>
            <field name="view_id" ref="kanban_view_student"/>
            <field name="domain">[("is_enrolled_student","=",True)]</field>
        </record>

        <record id="action_vm_application_student" model="ir.actions.act_window">
            <field name="name">Students Application</field>
            <field name="res_model">vm.student</field>
            <field name="view_mode">kanban,list,form</field>
            <field name="view_id" ref="kanban_view_student"/>
            <field name="domain">[("is_enrolled_student","=",False)]</field>
        </record>


