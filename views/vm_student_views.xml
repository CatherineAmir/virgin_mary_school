<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <record id="kanban_view_student" model="ir.ui.view">
            <field name="name">Student Kanban</field>
            <field name="model">vm.student</field>
            <field name="arch" type="xml">
                <kanban sample="1" class="o_kanban_mobile">
                    <field name="id"/>
                    <field name="image_1920"/>
                    <templates>
                        <t t-name="card" class="flex-row">
                            <widget name="web_ribbon" title="Archived" bg_color="text-bg-danger" invisible="active"/>
                            <aside class="o_kanban_aside_full">
                                <t t-if="record.image_1920.value">
                                    <div class="o_kanban_image_fill position-relative w-100">
                                        <field name="image_1920" alt="Contact image" class="h-100" widget="image"
                                               options="{'img_class': 'object-fit-cover'}"/>
                                    </div>
                                </t>
                                <t t-else="">
                                    <div class="o_kanban_image_fill position-relative w-100">
                                        <field name="avatar_128" class="h-100" widget="image"
                                               options="{'img_class': 'object-fit-cover'}"/>
                                    </div>
                                </t>
                            </aside>
                            <main class="ml16 ps-2 ps-md-0">
                                <div class="mb-1">
                                    <field name="name" class="mb-0 fw-bold fs-5"/>
                                </div>

                                <div class="mb-1">
                                    <field name="name_arabic" class="mb-0 fw-bold fs-5"/>
                                </div>

                                <div class="text-truncate">
                                    <i class="fa fa-fw me-2 fa-home text-primary" title="grade_id"
                                       t-if="record.grade_id"/>
                                    <field name="grade_id" class="text-truncate"/>
                                </div>
                                <div class="text-truncate">
                                    <i class="fa fa-fw me-2 fa-calendar text-primary" title="birth_date"
                                       t-if="record.birth_date"/>
                                    <field name="birth_date" class="text-truncate"/>
                                </div>
                                <div class="text-truncate">
                                    <i class="fa fa-fw me-2 fa-user text-primary" title="Gender" t-if="record.gender"/>
                                    <field name="gender" class="text-truncate"/>
                                </div>
                                <!--                                <footer class="py-0">-->
                                <!--                                    <div class="d-flex ms-auto">-->
                                <!--                                        <field name="activity_ids" widget="kanban_activity" class="m-2 ms-2"/>-->
                                <!--                                    </div>-->
                                <!--                                </footer>-->
                            </main>
                        </t>
                    </templates>
                </kanban>
            </field>
        </record>


        <!-- List (Tree) view -->
        <record id="view_vm_student_tree" model="ir.ui.view">
            <field name="name">vm_student.tree</field>
            <field name="model">vm.student</field>
            <field name="arch" type="xml">
                <list string="Students" create="true" edit="true" delete="true">
                    <field name="name"/>
                    <field name="name_arabic"/>
                    <field name="stage_id"/>
                    <field name="grade_id"/>

                    <field name="national_id"/>
                    <field name="nationality"/>
                    <field name="birth_date"/>
                    <field name="gender"/>
                    <field name="partner_id"/>
                    <field name="user_id"/>
                    <field name="active"/>
                </list>
            </field>
        </record>

        <!-- Form view -->
        <record id="view_vm_student_form" model="ir.ui.view">
            <field name="name">vm_student.form</field>
            <field name="model">vm.student</field>
            <field name="arch" type="xml">
                <form string="Student">
                    <header>
                    </header>
                    <sheet>
                        <div name="button_box" class="oe_button_box">
                            <button name="get_parent"
                                    class="btn oe_stat_button"
                                    icon="fa-user-o"
                                    type="object">

                                <div class="o_field_widget o_stat_info">
                                    <span class="o_stat_text">Parents</span>
                                </div>
                            </button>
                        </div>
                        <field name="stage_id" invisible="is_enrolled_student" widget="statusbar" options="{'clickable': '1'}"/>
                        <field name="grade_id" invisible="not is_enrolled_student" widget="statusbar" options="{'clickable': '1'}"/>

                        <field name="active" invisible="1"/>
                        <widget name="web_ribbon" title="Archived" bg_color="bg-danger"
                                invisible="active == True"/>
                        <group>
                            <group>
                                <div class="oe_title">
                                    <label for="name"/>
                                    <h1>
                                        <field name="name" placeholder="Full name English"/>
                                        <field name="name_arabic" placeholder="Full name Arabic"/>
                                    </h1>

                                </div>
                            </group>


                            <div class="o_employee_avatar ms-2 p-0 h-100 mw-25 align-self-end align-self-sm-end">
                                <field name="image_1920" widget='image' class="m-0 float-end"
                                       options='{"size": [128,158], "zoom": true, "preview_image":"avatar_128"}'/>
                            </div>

                        </group>
                        <group>
                            <group>
                                <field name="place_of_birth"/>
                                <field name="gender"/>
                                <field name="religion"/>
                                <field name="transportation"/>


                            </group>
                            <group>
                                <field name="is_enrolled_student" readonly="1"/>
                                <field name="grade_id"/>
                                <field name="previous_school_name"/>
                                <field name="current_academic_year"/>
                                <field name="national_id"/>
                                <field name="nationality"/>

                                <field name="birth_date"/>
                                <label for="age_on_october"/>
                                <field name="date_required"/>
                                <div class="oe_inline">
                                    <field name="age_year" class="oe_inline"/>
                                    Years

                                    <field name="age_month" class="oe_inline"/>
                                    Months
                                    <field name="age_day" class="oe_inline"/>
                                    Days
                                </div>


                                <field name="age_on_october"/>
                            </group>
                        </group>

                        <notebook>
                            <page string="Personal">
                                <group>
                                    <field name="stage_id"/>
                                    <field name="partner_id" required="0"/>
                                    <field name="user_id"/>
                                </group>
                            </page>
                            <page string="Parents" name="parents">
                                <group>
                                    <field name="parent_ids" readonly="1">
                                        <list string="Parents" create="false" edit="true" delete="false">
                                            <field name="name"/>
                                            <field name="mobile"  widget="phone"/>
                                            <field name="relationship_id"/>
                                        </list>
                                    </field>
                                </group>
                            </page>
                            <page string="Address &amp; Notes">
                                <group>
                                    <field name="parent_marital_status"/>
                                    <field name="legal_custodian"/>
                                    <field name="detailed_address" colspan="2"/>
                                </group>
                            </page>
                            <page string="Siblings Data">
                                <group>
                                    <field name="number_of_brothers"/>
                                    <field name="number_of_sisters"/>
                                </group>
                                <group>
                                    <field name="siblings_ids">
                                        <list string="Siblings" create="true" edit="true" delete="true">
                                            <field name="student_id" column_invisible="1"/>
                                            <field name="name"/>
                                            <field name="grade_id"/>
                                        </list>
                                    </field>
                                </group>
                            </page>
                        </notebook>

                        <chatter/>
                        >
                    </sheet>
                </form>
            </field>
        </record>

        <!-- Search view -->
        <record id="view_vm_student_search" model="ir.ui.view">
            <field name="name">vm_student_search</field>
            <field name="model">vm.student</field>
            <field name="arch" type="xml">
                <search string="Students">
                    <field name="name"/>
                    <field name="name_arabic"/>

                    <field name="national_id"/>
                    <field name="stage_id"/>
                    <field name="nationality"/>
                    <field name="gender"/>
                    <separator/>

                    <filter string="Active" name="filter_active" domain="[('active', '=', True)]"/>
                    <filter string="Enrolled" name="filter_enrolled" domain="[('is_enrolled_student', '=', True)]"/>
                    <separator/>

                    <filter name="group_by_stage" string="Stage" domain="[]" context="{'group_by':'stage_id'}"/>
                    <filter name="group_by_nationality" string="Nationality" domain="[]"
                            context="{'group_by':'nationality'}"/>
                    <filter name="group_by_gender" string="Gender" domain="[]" context="{'group_by':'gender'}"/>
                    <filter name="group_grade_id" context="{'group_by':'grade_id'}" string="Grade"/>
                    <filter name="group_national_id" context="{'group_by':'national_id'}" string="National ID"/>

                </search>
            </field>
        </record>
