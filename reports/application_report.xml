<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Report Action -->
    <record id="application_report_action_report" model="ir.actions.report">
        <field name="name">Student Application Report</field>
        <field name="model">vm.student</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">virgin_mary_school.report_application_report</field>
        <field name="report_file">virgin_mary_school.report_application_report</field>
        <field name="print_report_name">(object._get_report_filename())</field>
        <field name="binding_model_id" ref="model_vm_student"/>
        <field name="binding_type">report</field>
    </record>

    <!-- Report Template -->
    <template id="report_application_report_document">
        <t t-call="web.external_layout">
            <t t-set="doc" t-value="doc.with_context(lang=doc.partner_id.lang)"/>
            <div class="page">


                <div class="oe_structure"/>


                <h2>
                    <span t-esc="doc.name.capitalize()"/>
                </h2>
                <h2 class="my-3">
                    <span t-field="doc.name_arabic"/>
                </h2>

                <div class="row mt-2 mt32 mb32">

                    <div class="col col-6 mx-3">
                        <strong>Student Grade:</strong>
                        <t t-out="doc.grade_id.name"/>
                    </div>
                    <div class="col col-6 mx-3">
                        <strong>Current Academic Year:</strong>
                        <t t-out="doc.current_academic_year.name"/>
                    </div>
                </div>

                <!--                birthday and national id-->

                <div class="row mt-2 mt32 mb32">

                    <div class="col col-6 mx-3">
                        <strong>Birth Date</strong>
                        <t t-out="doc.birth_date"/>
                    </div>
                    <div class="col col-6 mx-3">
                        <strong>National Id:</strong>
                        <t t-out="doc.national_id"/>
                    </div>
                </div>
                <!--                    Age on october and gender-->
                <div class="row mt32 mb32">

                    <div class="col col-6 mx-3">
                        <strong>Age On October:</strong>
                        <t t-out="doc.age_on_october"/>
                    </div>
                    <div class="col col-6 mx-3">
                        <strong>Gender :</strong>
                        <t t-out="doc.gender.capitalize()"/>
                    </div>
                </div>
                <!--                    place of birth and religion-->
                <div class="row mt32 mb32">

                    <div class="col col-6 mx-3">
                        <strong>Place Of Birth:</strong>
                        <t t-out="doc.place_of_birth"/>
                    </div>
                    <div class="col col-6 mx-3">
                        <strong>Religion:</strong>

                        <t t-out="doc.religion.capitalize()"/>

                    </div>
                </div>
                <div class="row mt32 mb32">
                    <!--                    Nationality and Previous  school name-->
                    <div class="col col-6 mx-3">
                        <strong>Nationality:</strong>
                        <t t-out="doc.nationality.name"/>
                    </div>

                    <div class="col col-6 mx-3">
                        <strong>Previous School Name:</strong>
                        <t t-if="doc.previous_school_name">
                            <t t-out="doc.previous_school_name"/>
                        </t>
                        <t t-else="">
                            <span>----------</span>
                        </t>
                    </div>
                </div>

                <div class="row mt32 mb32">

                    <div class="col col-6 mx-3">
                        <strong>Parent Marital Status:</strong>
                        <t t-out="doc.parent_marital_status.capitalize()"/>
                    </div>
                    <div class="col col-6 mx-3">
                        <strong>Legal Custodian:</strong>

                        <t t-out="doc.legal_custodian"/>

                    </div>
                </div>
                <!--                Brothers and Sisters-->
                <div class="row mt32 mb32">

                    <div class="col col-6 mx-3">
                        <strong>Number of Brothers:</strong>
                        <t t-out="doc.number_of_brothers"/>
                    </div>
                    <div class="col col-6 mx-3">
                        <strong>Number of Sisters:</strong>

                        <t t-out="doc.number_of_sisters"/>

                    </div>
                </div>

                <!--                    Detailed Address:-->
                <div class="row mt32 mb32">

                    <div class="col col-12 mx-3">
                        <strong>Detailed Address:</strong>
                        <t t-out="doc.detailed_address"/>
                    </div>


                </div>
                <h6 class="text-center my-5">
                    Parents Data
                </h6>

                <t t-foreach="doc.parent_ids[:2]" t-as="parent">
                    <div class="text-center my-5">
                        <strong class="" t-out="parent.relationship_id.name">Data</strong>
                    </div>


                    <div class="row mt32 mb32">

                        <div class="col col-6 mx-3">
                            <strong>Name:</strong>
                            <t t-out="parent.name.name"/>
                        </div>
                        <div class="col col-6 mx-3">
                            <strong>Phone :</strong>
                            <t t-out="parent.mobile"/>
                        </div>
                    </div>

                    <div class="row mt32 mb32">

                        <div class="col col-6 mx-3">
                            <strong>Job:</strong>
                            <t t-out="parent.job"/>
                        </div>
                        <div class="col col-6 mx-3">
                            <strong>National id:</strong>

                            <t t-out="parent.national_id"/>

                        </div>
                    </div>
                    <div class="row mt32 mb32">
                        <!--                    Nationality and Previous  school name-->
                        <div class="col col-6 mx-3">
                            <strong>Email:</strong>
                            <t t-out="parent.email"/>
                        </div>

                        <div class="col col-6 mx-3">
                            <strong>Address:</strong>

                            <t t-out="parent.address"/>

                        </div>

                    </div>

                    <br/>
                </t>


                <!--                Parents Data-->


                <h3 class=" my-4" style="color:#12396e;" >
                    <t t-out="doc.name" />
                </h3>
                <h3 class="my-3" style="color:#12396e;">
                    <t t-out="doc.name_arabic"/>
                </h3>

                <h6 class="text-center my-4">
                    Siblings Data
                </h6>
                <table class="table table-sm o_main_table">
                    <thead>
                        <tr>
                            <th name="th_name" class="text-left">Name</th>
                            <th name="th_grade" class="text-right">Grade</th>
                        </tr>
                    </thead>
                    <tbody>
                        <t t-if="doc.siblings_ids">


                            <t t-foreach="doc.siblings_ids" t-as="sib">
                                <tr>
                                    <td name="td_name">
                                        <span t-out="sib.name"/>
                                    </td>
                                    <td name="td_grade" class="text-right">
                                        <span t-out="sib.grade_id.name"/>
                                    </td>
                                </tr>
                            </t>
                        </t>

                        <t t-foreach="range(0,3)" t-as="i">
                            <tr>


                                <td name="td_name">
                                    <!--                                    <span style="width:100px;"></span>-->
                                    <span style="display: inline-block; width: 200px; border-bottom: 1px solid #000;"></span>
                                </td>
                                <td name="td_grade" class="text-right">
                                    <span style="display: inline-block; width: 200px; border-bottom: 1px solid #000;"></span>
                                </td>
                            </tr>
                        </t>
                        <!--                        </t>-->
                    </tbody>
                </table>


                <div class="oe_structure"/>
                <!--                <t t-call="virgin_mary_school.report_application_report_footer"/>-->
            </div>
        </t>
    </template>
    <template id="inherit_external_standard_id" inherit_id="web.external_layout_standard" name="Signatures">
        <xpath expr="//*[contains(@t-attf-class, 'footer')]//div[hasclass('o_footer_content')]" position="before">

            <div class="row mb-2">
                <div class="d-flex justify-content-end align-items-center gap-2 flex-nowrap">
                    <label for="check" class="ms-2 mb-0 text-nowrap">أقر بصحة البيانات السابقة</label>
                    <input type="checkbox" id="check"
                           style="width: 18px; height: 18px; cursor: pointer; flex-shrink: 0;"/>
                </div>
            </div>

            <div class="row mt-3">
                <div class="col-4 mb4">
                    <span class="float-start my-2">التوقيع</span>
                </div>
                <div class="col-4 mb4">
                    <span class="float-start my-2">
                        درجة القرابة
                    </span>
                </div>
                <div class="col-4 mb4">
                    <span class="float-start my-2">الاسم

                    </span>
                </div>
            </div>
            <div class="row">
                <div class="col-4 mb4">

                    <span>--------------</span>
                </div>
                <div class="col-4 mb4">

                    <span>-------------</span>
                </div>
                <div class="col-4 mb4">

                    <span>------------</span>
                </div>
            </div>


        </xpath>
    </template>


    <template id="report_application_report">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="doc">

                <t t-call="virgin_mary_school.report_application_report_document" t-lang="doc.partner_id.lang"/>
            </t>
        </t>
    </template>
</odoo>